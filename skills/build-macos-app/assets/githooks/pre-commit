#!/usr/bin/env bash
# Swift quality pre-commit hook
# Generated by the build-macos-app skill.
#
# Runs against staged .swift files only — typically <1s on incremental commits.
# Aborts on the first failure. Stages run in this order:
#
#   1. SwiftLint --strict       — every warning becomes commit-blocking
#   2. SwiftFormat --lint       — fails if formatting would change any file
#   3. scripts/check-quality.sh — repo-side custom guardrail (optional)
#   4. Swift typecheck          — opt-in via SWIFT_HOOK_TYPECHECK=1
#
# Skip the hook for an emergency commit: git commit --no-verify
# CI is auto-detected via $CI and the hook self-skips.
#
# Install with:    git config core.hooksPath .githooks   (or `make install-hooks`)
# Uninstall with:  git config --unset core.hooksPath

set -euo pipefail

# Skip in CI — pipelines should run the same checks via `make lint-all`
if [ -n "${CI:-}" ]; then
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Collect staged Swift files (Added/Copied/Modified/Renamed). Exclude deletions.
STAGED_SWIFT=()
while IFS= read -r line; do
    [ -n "$line" ] && STAGED_SWIFT+=("$line")
done < <(git diff --cached --name-only --diff-filter=ACMR | grep '\.swift$' || true)

# Bail early if no Swift files staged
if [ ${#STAGED_SWIFT[@]} -eq 0 ]; then
    exit 0
fi

echo "→ pre-commit: ${#STAGED_SWIFT[@]} Swift file(s) staged"

# ─── Stage 1: SwiftLint ──────────────────────────────────────────────────
if command -v swiftlint >/dev/null 2>&1; then
    echo "→ swiftlint --strict (staged files only)"
    if ! swiftlint lint --quiet --strict "${STAGED_SWIFT[@]}"; then
        echo ""
        echo "✗ SwiftLint failed. Fix violations or run 'make lint-fix' and re-stage."
        exit 1
    fi
else
    echo "  ⚠ swiftlint not installed — skipping (brew install swiftlint)"
fi

# ─── Stage 2: Formatter (SwiftFormat or swift-format) ────────────────────
if command -v swiftformat >/dev/null 2>&1; then
    echo "→ swiftformat --lint (staged files only)"
    if ! swiftformat --lint --quiet "${STAGED_SWIFT[@]}"; then
        echo ""
        echo "✗ SwiftFormat would change staged files."
        echo "  Run 'make format' then re-stage the resulting changes."
        exit 1
    fi
elif command -v swift-format >/dev/null 2>&1; then
    echo "→ swift-format lint --strict (staged files only)"
    if ! swift-format lint --strict --configuration .swift-format "${STAGED_SWIFT[@]}"; then
        echo ""
        echo "✗ swift-format flagged formatting issues."
        echo "  Run 'swift-format format -i ${STAGED_SWIFT[*]}' and re-stage."
        exit 1
    fi
else
    echo "  ⚠ no formatter installed — skipping (brew install swiftformat)"
fi

# ─── Stage 3: Repo-side custom quality script (optional) ─────────────────
if [ -x "$REPO_ROOT/scripts/check-quality.sh" ]; then
    echo "→ scripts/check-quality.sh"
    if ! bash "$REPO_ROOT/scripts/check-quality.sh" >/dev/null 2>&1; then
        echo ""
        echo "✗ Custom quality check failed. Run 'bash scripts/check-quality.sh' for details."
        exit 1
    fi
fi

# ─── Stage 4: Swift typecheck (opt-in) ───────────────────────────────────
# Disabled by default because the Xcode build can be transiently broken
# (package sync, missing simulator runtime, expired certs) which would
# otherwise block every commit. Enable per-shell:
#
#   export SWIFT_HOOK_TYPECHECK=1
#
if [ "${SWIFT_HOOK_TYPECHECK:-0}" = "1" ]; then
    if [ ! -x "$REPO_ROOT/scripts/swift-typecheck.sh" ]; then
        echo "  ⚠ scripts/swift-typecheck.sh missing — skipping typecheck stage"
    else
        echo "→ swift typecheck (SWIFT_HOOK_TYPECHECK=1)"
        if ! bash "$REPO_ROOT/scripts/swift-typecheck.sh" "${STAGED_SWIFT[@]}"; then
            echo ""
            echo "✗ Swift typecheck failed."
            echo "  Disable for one commit: SWIFT_HOOK_TYPECHECK=0 git commit ..."
            exit 1
        fi
    fi
fi

echo "✓ pre-commit checks passed"
